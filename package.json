{
  "name": "openlightfx-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "prettier --check . && eslint .",
    "format": "prettier --write .",
    "proto:compile": "pbjs -t static-module -w es6 -o src/lib/proto/lightfx.js proto/lightfx.proto && pbts -o src/lib/proto/lightfx.d.ts src/lib/proto/lightfx.js",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron src/electron/main.ts\"",
    "electron:build": "npm run build && electron-builder"
  },
  "dependencies": {
    "@sveltejs/adapter-static": "^3.0",
    "@sveltejs/kit": "^2.16",
    "@sveltejs/vite-plugin-svelte": "^5.0",
    "autoprefixer": "^10",
    "postcss": "^8",
    "protobufjs": "^7.4",
    "svelte": "^5.0",
    "tailwindcss": "^3.4"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8",
    "eslint": "^9",
    "eslint-plugin-svelte": "^2",
    "prettier": "^3",
    "prettier-plugin-svelte": "^3",
    "protobufjs-cli": "^1.1",
    "svelte-check": "^4.0",
    "typescript": "^5",
    "vite": "^6"
  }
}
